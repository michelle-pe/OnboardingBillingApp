<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Billing App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            padding-top: 20px;
        }

            .sidebar a {
                color: #adb5bd;
                display: block;
                padding: 10px 20px;
                text-decoration: none;
            }

                .sidebar a:hover, .sidebar a.active {
                    color: #fff;
                    background-color: #343a40;
                }

            .sidebar .nav-header {
                color: #6c757d;
                padding: 10px 20px;
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .main-content {
            padding: 30px;
        }

        .page-header {
            border-bottom: 2px solid #dee2e6;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-md-2 sidebar px-0">
                <div class="text-white text-center py-3 border-bottom border-secondary">
                    <h5 class="mb-0">💰 BillingApp</h5>
                </div>
                <div class="nav-header mt-3">Main Menu</div>
                <a href="@Url.Action("Index","Dashboard")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Dashboard"  ? "active" : "")">🏠 Dashboard</a>
                <a href="@Url.Action("Index","Customer")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Customer"   ? "active" : "")">👤 Customers</a>
                <a href="@Url.Action("Index","Product")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Product"    ? "active" : "")">📦 Products</a>
                <a href="@Url.Action("Index","Invoice")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Invoice"    ? "active" : "")">🧾 Invoices</a>
            </div>

            <!-- Main content -->
            <div class="col-md-10 main-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/knockout@3.5.1/build/output/knockout-latest.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>