@{
    ViewBag.Title = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h3 class="mb-0"> Customers</h3>
    <button class="btn btn-primary" data-bind="click: openCreateModal">
        + New Customer
    </button>
</div>

<!-- Alert -->
<div data-bind="visible: alertMessage()" style="display:none">
    <div class="alert" data-bind="text: alertMessage, css: alertClass"></div>
</div>

<!-- Search -->
<div class="card mb-3">
    <div class="card-body py-2">
        <input type="text" class="form-control" placeholder="Search by name or email..."
               data-bind="value: searchTerm, valueUpdate: 'input'" />
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: filteredCustomers">
                <tr>
                    <td data-bind="text: CustomerId"></td>
                    <td data-bind="text: FirstName() + ' ' + LastName()"></td>
                    <td data-bind="text: Email"></td>
                    <td data-bind="text: Phone() || '—'"></td>
                    <td data-bind="text: Address() || '—'"></td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary me-1"
                                data-bind="click: $root.openEditModal">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                data-bind="click: $root.deleteCustomer">
                            Delete
                        </button>
                    </td>
                </tr>
            </tbody>
            <tbody data-bind="visible: filteredCustomers().length === 0">
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No customers found.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Loading spinner -->
<div class="text-center py-4" data-bind="visible: isLoading">
    <div class="spinner-border text-primary"></div>
</div>

<!-- -- Create / Edit Modal ------------------------------------------ -->
<div class="modal fade" id="customerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" data-bind="text: modalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- Validation error -->
                <div class="alert alert-danger" data-bind="visible: modalError(), text: modalError()"
                     style="display:none"></div>

                <div class="mb-3">
                    <label class="form-label">First Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control"
                           data-bind="value: form.FirstName, css: {'is-invalid': !form.FirstName()}" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Last Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control"
                           data-bind="value: form.LastName, css: {'is-invalid': !form.LastName()}" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email <span class="text-danger">*</span></label>
                    <input type="email" class="form-control"
                           data-bind="value: form.Email, css: {'is-invalid': !form.Email()}" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" class="form-control" data-bind="value: form.Phone" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <textarea class="form-control" rows="2" data-bind="value: form.Address"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary"
                        data-bind="click: saveCustomer, text: saveButtonText"></button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
    function CustomerViewModel() {
        var self = this;

        // -- State --------------------------------------------------
        self.customers      = ko.observableArray([]);
        self.searchTerm     = ko.observable('');
        self.isLoading      = ko.observable(false);
        self.alertMessage   = ko.observable('');
        self.alertClass     = ko.observable('alert-success');
        self.isEditing      = ko.observable(false);
        self.modalError     = ko.observable('');

        // Form observables
        self.form = {
            CustomerId : ko.observable(0),
            FirstName  : ko.observable(''),
            LastName   : ko.observable(''),
            Email      : ko.observable(''),
            Phone      : ko.observable(''),
            Address    : ko.observable('')
        };

        // -- Computed ------------------------------------------------
        self.modalTitle = ko.computed(function () {
            return self.isEditing() ? 'Edit Customer' : 'New Customer';
        });

        self.saveButtonText = ko.computed(function () {
            return self.isEditing() ? 'Update' : 'Create';
        });

        self.filteredCustomers = ko.computed(function () {
            var term = self.searchTerm().toLowerCase();
            if (!term) return self.customers();
            return ko.utils.arrayFilter(self.customers(), function (c) {
                return (c.FirstName() + ' ' + c.LastName()).toLowerCase().indexOf(term) > -1
                    || c.Email().toLowerCase().indexOf(term) > -1;
            });
        });

        // -- Load ----------------------------------------------------
        self.loadCustomers = function () {
            self.isLoading(true);
            $.get('@Url.Action("GetAll","Customer")', function (res) {
                if (res.success) {
                    // Map plain objects to observables so Knockout can track changes
                    var mapped = res.data.map(function (c) {
                        return {
                            CustomerId : ko.observable(c.CustomerId),
                            FirstName  : ko.observable(c.FirstName),
                            LastName   : ko.observable(c.LastName),
                            Email      : ko.observable(c.Email),
                            Phone      : ko.observable(c.Phone),
                            Address    : ko.observable(c.Address)
                        };
                    });
                    self.customers(mapped);
                }
                self.isLoading(false);
            });
        };

        // -- Modal helpers -------------------------------------------
        self.openCreateModal = function () {
            self.isEditing(false);
            self.modalError('');
            self.form.CustomerId(0);
            self.form.FirstName('');
            self.form.LastName('');
            self.form.Email('');
            self.form.Phone('');
            self.form.Address('');
            $('#customerModal').modal('show');
        };

        self.openEditModal = function (customer) {
            self.isEditing(true);
            self.modalError('');
            self.form.CustomerId(customer.CustomerId());
            self.form.FirstName(customer.FirstName());
            self.form.LastName(customer.LastName());
            self.form.Email(customer.Email());
            self.form.Phone(customer.Phone());
            self.form.Address(customer.Address());
            $('#customerModal').modal('show');
        };

        // -- Client-side validation ---------------------------------
        self.validateForm = function () {
            if (!self.form.FirstName()) { self.modalError('First name is required.'); return false; }
            if (!self.form.LastName())  { self.modalError('Last name is required.');  return false; }
            if (!self.form.Email())     { self.modalError('Email is required.');       return false; }
            var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(self.form.Email())) {
                self.modalError('Please enter a valid email address.');
                return false;
            }
            self.modalError('');
            return true;
        };

        // -- Save (Create or Update) ---------------------------------
        self.saveCustomer = function () {
            if (!self.validateForm()) return;

            var url  = self.isEditing()
                       ? '@Url.Action("Update","Customer")'
                       : '@Url.Action("Create","Customer")';

            var data = {
                CustomerId : self.form.CustomerId(),
                FirstName  : self.form.FirstName(),
                LastName   : self.form.LastName(),
                Email      : self.form.Email(),
                Phone      : self.form.Phone(),
                Address    : self.form.Address()
            };

            $.post(url, data, function (res) {
                if (res.success) {
                    $('#customerModal').modal('hide');
                    self.showAlert(res.message, 'alert-success');
                    self.loadCustomers();
                } else {
                    self.modalError(res.message);
                }
            });
        };

        // -- Delete ---------------------------------------------------
        self.deleteCustomer = function (customer) {
            if (!confirm('Delete ' + customer.FirstName() + ' ' + customer.LastName() + '?')) return;

            $.post('@Url.Action("Delete","Customer")', { id: customer.CustomerId() }, function (res) {
                if (res.success) {
                    self.showAlert(res.message, 'alert-success');
                    self.loadCustomers();
                } else {
                    self.showAlert(res.message, 'alert-danger');
                }
            });
        };

        // -- Alert helper --------------------------------------------
        self.showAlert = function (message, cssClass) {
            self.alertClass(cssClass);
            self.alertMessage(message);
            setTimeout(function () { self.alertMessage(''); }, 4000);
        };

        // -- Init -----------------------------------------------------
        self.loadCustomers();
    }

    ko.applyBindings(new CustomerViewModel());
    </script>
}