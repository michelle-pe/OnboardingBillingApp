@{
    ViewBag.Title = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h3 class="mb-0"> Customers</h3>
    <button class="btn btn-primary" data-bind="click: openCreateModal">
        + New Customer
    </button>
</div>

<!-- Alert -->
<div data-bind="visible: alertMessage()" style="display:none">
    <div class="alert" data-bind="text: alertMessage, css: alertClass"></div>
</div>

<!-- Search -->
<div class="card mb-3">
    <div class="card-body py-2">
        <input type="text" class="form-control" placeholder="Search by name or email..."
               data-bind="value: searchTerm, valueUpdate: 'input'" />
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: filteredCustomers">
                <tr>
                    <td data-bind="text: CustomerId"></td>
                    <td data-bind="text: FirstName() + ' ' + LastName()"></td>
                    <td data-bind="text: Email"></td>
                    <td data-bind="text: Phone() || '-'"></td>
                    <td data-bind="text: Address() || '-'"></td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary me-1"
                                data-bind="click: $root.openEditModal">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                data-bind="click: $root.deleteCustomer">
                            Delete
                        </button>
                    </td>
                </tr>
            </tbody>
            <tbody data-bind="visible: filteredCustomers().length === 0">
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No customers found.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Loading spinner -->
<div class="text-center py-4" data-bind="visible: isLoading">
    <div class="spinner-border text-primary"></div>
</div>

<!-- Create / Edit Modal -->
<div class="modal fade" id="customerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" data-bind="text: modalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger"
                     data-bind="visible: modalError(), text: modalError()"
                     style="display:none"></div>
                <div class="mb-3">
                    <label class="form-label">First Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control"
                           data-bind="value: form.FirstName, css: {'is-invalid': !form.FirstName()}" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Last Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control"
                           data-bind="value: form.LastName, css: {'is-invalid': !form.LastName()}" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email <span class="text-danger">*</span></label>
                    <input type="email" class="form-control"
                           data-bind="value: form.Email, css: {'is-invalid': !form.Email()}" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" class="form-control" data-bind="value: form.Phone" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <textarea class="form-control" rows="2"
                              data-bind="value: form.Address"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-primary"
                        data-bind="click: saveCustomer, text: saveButtonText"></button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/app/customer.js"></script>
    <script>
        ko.applyBindings(new CustomerViewModel(
            '@Url.Action("GetAll",   "Customer")',
            '@Url.Action("Create",  "Customer")',
            '@Url.Action("Update",  "Customer")',
            '@Url.Action("Delete",  "Customer")'
        ));
    </script>
}